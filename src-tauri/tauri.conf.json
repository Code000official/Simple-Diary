{
  "productName": "Simple Diary",
  "version": "0.1.0",
  "identifier": "com.simple-diary.app",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:4173",
    "beforeDevCommand": "cd client && npx vite",
    "beforeBuildCommand": "cd client && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Simple Diary",
        "width": 1024,
        "height": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}